{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "f3ebb03b0a754b97ac716210b9d11214",
    "m_Title": "Temperature range",
    "m_Content": "Ensures a range of colour, while keeping within a certain zone based on the heat value. E.g. a hot object shouldn't have any blue.\nI thought a 'max' section would be necessary when subtracting based on the dropoff range, to ensure the value didn't go below zero, but that doesn't seem to be necessary.",
    "m_TextSize": 0,
    "m_Theme": 0,
    "m_Position": {
